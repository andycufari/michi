# ── Michi's brain ────────────────────────────────────────────────
# Swap the provider in one line. The loop is provider-agnostic
# (everyone speaks OpenAI-style tool-calling except Anthropic, which
# we adapt internally).
#
# LLM_PROVIDER: qwen | deepseek | openai | anthropic | ollama
# DEFAULT = qwen (Qwen3-VL) — multimodal, so Michi can SEE the screen when it has
# no text (captchas, image buttons, photos) via `movicom ui shot`. The 30B-A3B MoE
# variant is fast + cheap (≈3B active) — ideal for an always-on agent.
LLM_PROVIDER=qwen

# Each provider reads its own base URL + key + model. Fill the one you use.

# Qwen3-VL (Alibaba DashScope, OpenAI-compatible mode) — MULTIMODAL
# Models: qwen3-vl-30b-a3b-instruct (the ~27B MoE, fast/cheap) ·
#         qwen3-vl-32b-instruct (dense, stronger) · qwen3-vl-plus (hosted, hi-res)
QWEN_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1
QWEN_API_KEY=
QWEN_MODEL=qwen3-vl-30b-a3b-instruct
QWEN_VISION=1

# DeepSeek (https://platform.deepseek.com) — OpenAI-compatible, text-only
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat

# OpenAI
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# Anthropic (native API — adapted to the same tool loop)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# Ollama (local, free) — OpenAI-compatible at /v1
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_MODEL=qwen2.5:32b

# ── MichiOS server ───────────────────────────────────────────────
PORT=4488
# Token to call the API in "root mode" (you). Leave blank to disable auth (localhost only).
MICHI_TOKEN=

# Safety: max think→act iterations per task before MichiOS stops the loop.
MAX_STEPS=25
